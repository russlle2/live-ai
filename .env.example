# Server
PORT=8080
WS_PATH=/ws

# Database
DATABASE_URL=postgres://overlay:overlay@localhost:5432/overlay

# Demo mode: emit synthetic transcript_final blocks
STT_MOCK=1
STT_MOCK_INTERVAL_MS=2500
RETENTION_PRUNE_ENABLED=true
RETENTION_PRUNE_INTERVAL_MS=900000

# Arbitration locus: browser | backend | both
ARBITRATION_LOCUS=backend

# Optional: enable OpenAI rewrite (P3)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# CORS (web dev server)
WEB_ORIGIN=http://localhost:5173

# Optional: Protect server endpoints + WS start with a shared key
OVERLAY_API_KEY=
# Optional: Web client passes the same key in WS start + API calls
VITE_OVERLAY_API_KEY=

# Universal integration controls
UNIVERSAL_MODE=true
INTEGRATION_TIMEOUT_MS=7000
INTEGRATION_ALLOWED_HOSTS=localhost

# Server webhook connector
SERVER_WEBHOOK_URL=
SERVER_WEBHOOK_BEARER_TOKEN=
SERVER_WEBHOOK_SIGNING_SECRET=

# Zoom connector
ZOOM_WEBHOOK_URL=
ZOOM_BEARER_TOKEN=
ZOOM_SIGNING_SECRET=

# Google Meet connector
GOOGLE_MEET_WEBHOOK_URL=
GOOGLE_MEET_BEARER_TOKEN=
GOOGLE_MEET_SIGNING_SECRET=

# Google Workspace connector
GOOGLE_WORKSPACE_WEBHOOK_URL=
GOOGLE_WORKSPACE_BEARER_TOKEN=
GOOGLE_WORKSPACE_SIGNING_SECRET=

# OAuth (tenant-scoped token storage)
# 32-byte key as hex(64 chars) or base64, used for AES-256-GCM encryption at rest
OAUTH_TOKEN_ENC_KEY=

# Zoom OAuth app
ZOOM_OAUTH_CLIENT_ID=
ZOOM_OAUTH_CLIENT_SECRET=
ZOOM_OAUTH_AUTH_URL=https://zoom.us/oauth/authorize
ZOOM_OAUTH_TOKEN_URL=https://zoom.us/oauth/token
ZOOM_OAUTH_SCOPE=meeting:read user:read

# Google OAuth app
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_AUTH_URL=https://accounts.google.com/o/oauth2/v2/auth
GOOGLE_OAUTH_TOKEN_URL=https://oauth2.googleapis.com/token
GOOGLE_OAUTH_SCOPE=openid profile email
