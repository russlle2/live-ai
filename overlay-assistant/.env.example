# ═══════════════════════════════════════════════════════════
# Overlay Assistant — Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────
PORT=8080
WEB_ORIGIN=http://localhost:5173
TRUST_PROXY=false

# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgres://overlay:overlay@localhost:5432/overlay
# Set true for cloud databases that require SSL (e.g. Neon, Supabase, RDS)
# DB_SSL=false

# ── OpenAI (AI Coaching) ─────────────────────────────────
# Get your key at https://platform.openai.com/api-keys
# Without this, the app uses template-based coaching (still works, just less smart)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Authentication (JWT) ─────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# When not set, the app runs in DEMO MODE (no auth enforced)
JWT_SECRET=
# AUTH_TOKEN_TTL=8h
# Set true only for controlled demos; production should keep this false.
ALLOW_INSECURE_DEMO_AUTH=false

# ── Rate Limiting ────────────────────────────────────────
# RATE_LIMIT_PER_SESSION=60
# RATE_LIMIT_PER_TENANT_HOUR=200
# RATE_LIMIT_PER_TENANT_MINUTE=20

# ── Credential Encryption (OAuth storage) ────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIAL_ENCRYPTION_KEY=

# ── Speech-to-Text Mock (for testing without a mic) ──────
# STT_MOCK=true
# STT_MOCK_INTERVAL_MS=5000

# ── Arbitration ──────────────────────────────────────────
# Options: browser | backend | both
ARBITRATION_LOCUS=backend

# ── Performance & Limits ─────────────────────────────────
# MAX_WS_CONNECTIONS=500
# SESSION_TIMEOUT_MS=1800000
# Set COMPRESSION=0 to disable gzip (useful behind a CDN that compresses)
# COMPRESSION=1
