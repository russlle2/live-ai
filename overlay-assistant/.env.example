# Live Rhetoric — example only. Keep real values in ../.env.local.

# Server
PORT=8080
HOST=127.0.0.1
WEB_ORIGIN=http://localhost:5173
# One exact origin only. `*` is rejected; non-loopback deployments require HTTPS.
# Compose serves the built web app and API from the same origin. Keep the host
# bind on loopback unless an authenticated HTTPS reverse proxy is in front.
COMPOSE_WEB_ORIGIN=http://localhost:8080
APP_BIND_ADDRESS=127.0.0.1
TRUST_PROXY=false
COMPRESSION=1

# OpenAI. Never expose the standard key to the browser.
OPENAI_API_KEY=
OPENAI_LIVE_MODEL=gpt-5.6-luna
OPENAI_DEEP_MODEL=gpt-5.6-terra
OPENAI_REASONING_EFFORT=none
OPENAI_TRANSCRIPTION_MODEL=gpt-realtime-whisper
OPENAI_TRANSCRIPTION_DELAY=minimal

# Private local state. These paths are ignored by Git.
PERSONAL_MEMORY_PATH=./data/private/personal_memory.local.json
SESSION_LOG_DIR=./data/private/sessions
PERSONAL_AUTH_STATE_PATH=./data/private/personal_auth.local.json
MEMORY_MAX_PROMPT_FACTS=12
# Linux Docker only: set once to the output of `id -u` and `id -g` so the
# non-root app container can write the host-mounted private directory.
LIVE_AI_UID=1000
LIVE_AI_GID=1000

# Generic professional coaching knowledge stays separate from personal memory.
# Every row carries provenance; only reviewed sources enter live retrieval.
COACHING_CORPUS_PATHS=./data/coaching/seed_examples_v1.jsonl,./data/coaching/original_expansion_customer_v1.jsonl,./data/coaching/original_expansion_growth_v1.jsonl
COACHING_SOURCE_MANIFEST_PATH=./data/coaching/source_manifest_v1.json
COACHING_MAX_PROMPT_EXAMPLES=3

# Automatic owner-voice enrollment and fail-closed verification. The browser
# sends only short clean microphone segments; the service stores one embedding,
# never raw audio. Docker supplies http://speaker:8791 automatically.
SPEAKER_SERVICE_URL=http://127.0.0.1:8791
SPEAKER_SERVICE_API_TOKEN=
SPEAKER_SERVICE_TIMEOUT_MS=6000
SPEAKER_SERVICE_MAX_PAYLOAD_BYTES=524288
SPEAKER_MODEL_ID=anton-l/wav2vec2-base-superb-sv
SPEAKER_MODEL_REVISION=eb0be47779dda10620d068ab579fca970ee7e417
SPEAKER_OWNER_THRESHOLD=0.90
SPEAKER_MIN_ENROLLMENT_SAMPLES=3

# One-time Gmail + Drive connection. Create one Google OAuth web client with
# these readonly APIs enabled; after the first consent, refresh and sync are
# automatic. Tokens, cursors, and source cache stay under data/private.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/api/google/oauth/callback
GOOGLE_SYNC_DIR=./data/private/google
# At least 32 characters. This is optional only for the managed loopback host
# launcher, which creates a distinct private-storage key. It is required when
# JWT/PAC auth is supplied by environment (including containers/proxies).
# Existing plaintext Google state is encrypted on its first successful read.
GOOGLE_STORAGE_ENCRYPTION_KEY=
GOOGLE_SYNC_BATCH_SIZE=10
GOOGLE_SYNC_MAX_PAGES=2
GOOGLE_SYNC_INTERVAL_MS=21600000
GOOGLE_REQUEST_TIMEOUT_MS=15000
GOOGLE_MAX_JSON_RESPONSE_BYTES=2097152
GOOGLE_MAX_TEXT_RESPONSE_BYTES=1000000
# Deep extraction calls are checkpointed and capped even when Sync is clicked repeatedly.
GOOGLE_MAX_EXTRACTIONS_PER_RUN=5
GOOGLE_DAILY_EXTRACTION_BUDGET=40
GOOGLE_MAX_CACHED_SOURCES=1000
# Gmail bootstrap excludes Spam/Trash. Drive defaults to supported text/Google-doc types.
GOOGLE_GMAIL_QUERY=-in:spam -in:trash
GOOGLE_DRIVE_QUERY=

# PostgreSQL analytics/session metadata
DATABASE_URL=postgres://overlay:overlay@localhost:5432/overlay
# `false` is correct for the local Compose network. For a remote database, use
# a DNS hostname in DATABASE_URL and set true; CA and hostname checks stay on.
# Leave DB_SSL_CA_FILE empty to use the operating system trust store, or point
# it to a PEM CA bundle. Do not put ssl/sslmode options in DATABASE_URL.
DB_SSL=false
DB_SSL_CA_FILE=

# Optional explicit overrides. If both are omitted, first launch creates strong
# owner-only values under data/private; the laptop reads its pairing code only
# over loopback and a phone enters that code once. Never copy these into Git.
JWT_SECRET=
PERSONAL_ACCESS_CODE=
AUTH_TOKEN_TTL=8h
# No-auth mode is always explicit, including in development. Leave false except
# for a temporary loopback-only demo; JWT mode requires a 32+ character secret.
ALLOW_INSECURE_DEMO_AUTH=false

# Limits
RATE_LIMIT_PER_SESSION=500
RATE_LIMIT_PER_TENANT_HOUR=2000
RATE_LIMIT_PER_TENANT_MINUTE=120
MAX_WS_CONNECTIONS=20
MAX_WS_CONNECTIONS_PER_IP=6
SESSION_TIMEOUT_MS=14400000

# Optional legacy settings
ARBITRATION_LOCUS=backend
STT_MOCK=false
STT_MOCK_INTERVAL_MS=5000
