# ═══════════════════════════════════════════════════════════
# Overlay Assistant — Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────
PORT=8080
WEB_ORIGIN=*

# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgres://overlay:overlay@localhost:5432/overlay

# ── OpenAI (AI Coaching) ─────────────────────────────────
# Get your key at https://platform.openai.com/api-keys
# Without this, the app uses template-based coaching (still works, just less smart)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Authentication (JWT) ─────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# When not set, the app runs in DEMO MODE (no auth enforced)
JWT_SECRET=

# ── Rate Limiting ────────────────────────────────────────
# RATE_LIMIT_PER_SESSION=60
# RATE_LIMIT_PER_TENANT_HOUR=200
# RATE_LIMIT_PER_TENANT_MINUTE=20

# ── Credential Encryption (OAuth storage) ────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIAL_ENCRYPTION_KEY=

# ── Speech-to-Text Mock (for testing without a mic) ──────
# STT_MOCK=true
# STT_MOCK_INTERVAL_MS=5000

# ── Arbitration ──────────────────────────────────────────
# Options: browser | backend | both
ARBITRATION_LOCUS=backend
